# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
APP_POSTGRES_DB="acs_grader"
APP_POSTGRES_USER="acs_grader"
APP_POSTGRES_PASSWORD="replace-with-a-secure-password"

# App / auth
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="replace-with-a-random-secret"

# OAuth providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Email (required in production for verification emails)
RESEND_API_KEY=""
EMAIL_FROM="ACS Grader <noreply@example.com>"

# Judge0
JUDGE0_BASE_URL="http://localhost:2358"
# JUDGE0_URL is accepted by the sample-run endpoint as a fallback alias.
JUDGE0_URL=""

# OpenRouter test-case generation
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="qwen/qwen-2.5-7b-instruct:free"
OPENROUTER_FALLBACK_MODEL="liquid/lfm-2.5-1.2b-instruct:free"
OPENROUTER_SITE_URL="http://localhost:3000"
OPENROUTER_APP_NAME="acs-grader"

# Build
NEXT_STANDALONE="false"
